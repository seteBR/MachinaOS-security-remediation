# Copy to .env.production and rotate every secret before deployment.

MACHINAOS_BIND=127.0.0.1
MACHINAOS_PORT=3010

HOST=0.0.0.0
PORT=3010
SERVE_STATIC_CLIENT=true
DATA_DIR=/data
DEBUG=false
WORKERS=1

VITE_AUTH_ENABLED=true
AUTH_MODE=single
MACHINA_OWNER_EMAIL=admin@example.local
MACHINA_OWNER_NAME=Owner
MACHINA_OWNER_PASSWORD=change-this-password

SECRET_KEY=change-this-48-plus-char-secret
JWT_SECRET_KEY=change-this-48-plus-char-jwt-secret
API_KEY_ENCRYPTION_KEY=change-this-48-plus-char-encryption-secret
JWT_EXPIRE_MINUTES=10080
JWT_COOKIE_NAME=machina_token
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=lax

CORS_ORIGINS=["http://localhost:3010","http://127.0.0.1:3010"]

WORKFLOW_DB_FILENAME=workflow.db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

REDIS_ENABLED=false
CACHE_TTL=300

TEMPORAL_ENABLED=false
TEMPORAL_SERVER_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=machina-tasks
TEMPORAL_PER_TYPE_DISPATCH=false
TEMPORAL_AGENT_WORKFLOW_ENABLED=false
TEMPORAL_FRONTEND_GRPC_PORT=7233
TEMPORAL_UI_PORT=8080
TEMPORAL_SQLITE_PATH=temporal.db
TEMPORAL_TERMINATE_RUNNING_ON_STARTUP=true
TEMPORAL_GRACEFUL_SHUTDOWN_SECONDS=30

EVENT_FRAMEWORK_ENABLED=false
COMPACTION_ENABLED=true
COMPACTION_RATIO=0.8
AGENT_RECURSION_LIMIT=200

NODEJS_EXECUTOR_HOST=127.0.0.1
NODEJS_EXECUTOR_PORT=3020
NODEJS_EXECUTOR_URL=http://127.0.0.1:3020

BROWSER_MAX_INSTANCES=3
BROWSER_IDLE_TIMEOUT_MS=600000
DLQ_ENABLED=false

WORKSPACE_BASE_DIR=workspaces
LOG_LEVEL=INFO
LOG_FORMAT=text

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

AI_TIMEOUT=60
AI_MAX_RETRIES=1
AI_RETRY_DELAY=0.5
MAPS_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60
CLEANUP_ENABLED=true
CLEANUP_INTERVAL=3600
CLEANUP_LOGS_MAX_COUNT=1000
CLEANUP_CACHE_MAX_AGE_HOURS=24
WS_LOGGING_ENABLED=true
