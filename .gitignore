# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# =============================================================================
# SECURITY - Credentials and Secrets (NEVER COMMIT)
# =============================================================================
# Environment variables (contain API keys, secrets)
.env
.env.*
!.env.template
!.env.example
server/.env
server/.env.*
!server/.env.template
!server/.env.example

# API Keys and Credentials
**/credentials.json
**/secrets.json
**/apikeys.json
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx

# WhatsApp RPC is now an npm dependency (@anthropic/whatsapp-rpc)
# Session data is stored in node_modules/@anthropic/whatsapp-rpc/data/

# =============================================================================
# Database files (may contain sensitive user data)
# =============================================================================
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal
server/api/db/
server/*.db
server/data/

# =============================================================================
# Editor and IDE
# =============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =============================================================================
# OS and System files
# =============================================================================
.DS_Store
Thumbs.db
*.pyc
__pycache__/

# Backup files
*.bak
*.backup
*~

# Windows reserved files
nul
NUL

# Test artifacts — when a test passes a MagicMock to Path(...).mkdir
# the mock's repr() materialises as a real folder tree. Belt-and-braces
# guard so future stray runs don't pollute the worktree.
MagicMock/

# =============================================================================
# Build artifacts
# =============================================================================
build/
*.tgz
*.exe
*.dll
*.so
*.dylib

# =============================================================================
# Python
# =============================================================================
.venv/
venv/
*.egg-info/
.eggs/

# uv (Python package manager)
uv.lock
server/uv.lock
.python-version
server/.python-version

# =============================================================================
# pnpm
# =============================================================================
pnpm-store/
.pnpm-debug.log

# =============================================================================
# Temporary and cache files
# =============================================================================
*.tmp
*.temp
.cache/
*.cache

# =============================================================================
# Claude Code configuration + per-workflow runtime data
# =============================================================================
# Claude Code's local config / session state / scheduled tasks.
.claude/
# Per-workflow runtime workspace (CLAUDE.md "Per-Workflow Workspace
# Directory" — `data/workspaces/<workflow_id>/`). User-uploaded files,
# downloaded artifacts, agent-shell state. Always machine-local.
/data/
# Patch archive left behind by `git format-patch` during one-off
# merges (see ../.merge-archive cleanup commits). Never committed.
.merge-archive/

# =============================================================================
# Documentation (docs-MachinaOs is a separate GitHub project)
# =============================================================================
docs-MachinaOs/

# =============================================================================
# Experiments (work in progress)
# =============================================================================
server/experiments/
